# macOS
.DS_Store

# Exports (machine-specific, regenerated by collection scripts)
exports/macos/*.plist
exports/macos/*.txt
exports/brew/*.txt
exports/reports/*.md
exports/reports/*.txt

# Ansible retry files
*.retry

# Ansible Galaxy installed roles/collections
.ansible/

# Secrets — never commit these (unencrypted)
*.vault_password
.vault_password
**/*.key
**/*.pem
# Note: files/secrets/*.vault ARE committed (they're ansible-vault encrypted)

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
.venv/
venv/
