    "spellright.language": [
        "en"
    ],
    "spellright.documentTypes": [
        "markdown",
        "latex",
        "plaintext"
    ],
    "vs-kubernetes": {
        "vs-kubernetes.minikube-path.mac": "__USER_HOME__/.vs-kubernetes/tools/minikube/darwin-amd64/minikube",
        "vs-kubernetes.helm-path.mac": "__USER_HOME__/.vs-kubernetes/tools/helm/darwin-amd64/helm",
        "vs-kubernetes.draft-path.mac": "__USER_HOME__/.vs-kubernetes/tools/draft/darwin-amd64/draft",
        "vscode-kubernetes.minikube-path.mac": "__USER_HOME__/.vs-kubernetes/tools/minikube/darwin-arm64/minikube",
        "vscode-kubernetes.kubectl-path.mac": "__USER_HOME__/.vs-kubernetes/tools/kubectl/kubectl",
        "vscode-kubernetes.helm-path.mac": "__USER_HOME__/.vs-kubernetes/tools/helm/darwin-arm64/helm",
        "vscode-kubernetes.kubectl-path-mac": "__USER_HOME__/.vs-kubernetes/tools/kubectl/kubectl",
        "vscode-kubernetes.minikube-path-mac": "__USER_HOME__/.vs-kubernetes/tools/minikube/darwin-arm64/minikube",
        "vscode-kubernetes.helm-path-mac": "__USER_HOME__/.vs-kubernetes/tools/helm/darwin-arm64/helm",
        "vs-kubernetes.minikube-show-information-expiration": "2025-06-30T08:29:47.321Z"
    },
    "aws.telemetry": false,
    "telemetry.enableCrashReporter": false,
    "telemetry.enableTelemetry": false,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "none",
    "breadcrumbs.enabled": true,
    "files.associations": {
        "*.sh": "shellscript"
    },
    "shellcheck.enableQuickFix": true,
    "shellcheck.ignorePatterns": {
    


        "**/*.zsh": true,
        "**/*.zshrc": true,
        "**/zshrc": true,
        "**/*.zprofile": true,
        "**/zprofile": true,
        "**/*.zlogin": true,
        "**/zlogin": true,
        "**/*.zlogout": true,
        "**/zlogout": true,
        "**/*.zshenv": true,
        "**/zshenv": true,
        "**/*.zsh-theme": true
    },
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter.notebook.ipynb"
    },
    "yaml.customTags": [
        "!And",
        "!And sequence",
        "!If",
        "!If sequence",
        "!Not",
        "!Not sequence",
        "!Equals",
        "!Equals sequence",
        "!Or",
        "!Or sequence",
        "!FindInMap",
        "!FindInMap sequence",
        "!Base64",
        "!Join",
        "!Join sequence",
        "!Cidr",
        "!Ref",
        "!Sub",
        "!Sub sequence",
        "!GetAtt",
        "!GetAZs",
        "!ImportValue",
        "!ImportValue sequence",
        "!Select",
        "!Select sequence",
        "!Split",
        "!Split sequence"
    ],
    "yaml.validate": false,
    "redhat.telemetry.enabled": false,
    "explorer.confirmDelete": false,
    "yaml.schemas": {
        "file:__USER_HOME__/Library/Application Support/Code/User/globalStorage/amazonwebservices.aws-toolkit-vscode/sam.schema.json": [
            "storage/S3Storage/template.yaml"
        ],
        "file://__USER_HOME__/Library/Application%20Support/Code/User/globalStorage/amazonwebservices.aws-toolkit-vscode/sam.schema.json": [
            "storage/S3Storage/template.yaml"
        ],
        "file:///c%3A__USER_HOME__/AppData/Roaming/Code/User/globalStorage/amazonwebservices.aws-toolkit-vscode/sam.schema.json": [
            "storage/S3Storage/template.yaml"
        ]
    },
    "json.schemas": [],
    "remote.SSH.configFile": "~/.ssh/config",
    "cSpell.userWords": [
        "Boto",
        "CUDA",
        "cwagent",
        "shellcheck",
        "Stackname",
        "VCPU",
        "xlarge"
    ],
    "workbench.colorTheme": "Visual Studio Light",
    "editor.suggest.showMethods": true,
    "editor.suggest.preview": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.snippetSuggestions": "top",
    "editor.stickyScroll.enabled": true,
    "python.defaultInterpreterPath": "/opt/homebrew/Caskroom/miniconda/base/envs/aws",
    "window.zoomLevel": 1,
    "editor.accessibilitySupport": "off",
    "terminal.explorerKind": "both",
    "cSpell.enabledFileTypes": {
        "markdown": true,
        "shellscript": false,
        "dockerfile": false
    },
    "amazonQ.telemetry": false,
    "terminal.integrated.shellIntegration.enabled": true,
    "amazonQ.suppressPrompts": {
        "amazonQChatDisclaimer": true,
        "amazonQChatPairProgramming": true,
        "amazonQSessionConfigurationMessage": true,
        "codeWhispererConnectionExpired": true,
        "amazonQSelectDeveloperProfile": true
    },
    "docker.extension.enableComposeLanguageServer": false,
    "diffEditor.hideUnchangedRegions.enabled": true,
    "workbench.startupEditor": "none",
